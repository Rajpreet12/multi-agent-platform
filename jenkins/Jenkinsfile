pipeline {
  agent any

  environment {
    AWS_REGION      = "us-east-1"
    AWS_ACCOUNT_ID  = "903584666644"
    ECR_REPO        = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/multi-agent-backend"
    IMAGE_TAG       = "${BUILD_NUMBER}"
    NAMESPACE       = "multi-agent"
  }

  stages {
    stage("Checkout") {
      steps {
        checkout scm
      }
    }

    stage("Build & Push to ECR") {
      steps {
        withCredentials([
          usernamePassword(
            credentialsId: 'aws-credentials',
            usernameVariable: 'AWS_ACCESS_KEY_ID',
            passwordVariable: 'AWS_SECRET_ACCESS_KEY'
          )
        ]) {
          sh '''
            export AWS_DEFAULT_REGION="${AWS_REGION}"
            aws ecr get-login-password --region "${AWS_REGION}" | docker login --username AWS --password-stdin "${ECR_REPO}"
            docker build -t "${ECR_REPO}:${IMAGE_TAG}" -t "${ECR_REPO}:latest" ./app/backend
            docker push "${ECR_REPO}:${IMAGE_TAG}"
            docker push "${ECR_REPO}:latest"
          '''
        }
      }
    }

    stage("Deploy to EKS") {
      steps {
        withCredentials([
          usernamePassword(
            credentialsId: 'aws-credentials',
            usernameVariable: 'AWS_ACCESS_KEY_ID',
            passwordVariable: 'AWS_SECRET_ACCESS_KEY'
          )
        ]) {
          sh '''
            export AWS_DEFAULT_REGION="${AWS_REGION}"
            aws eks update-kubeconfig --region "${AWS_REGION}" --name multi-agent-test-cluster
            kubectl apply -f monitoring
            kubectl apply -f k8s/base
            kubectl set image deployment/multi-agent-backend backend="${ECR_REPO}:${IMAGE_TAG}" -n "${NAMESPACE}"
            kubectl rollout status deployment/multi-agent-backend -n "${NAMESPACE}"
            kubectl rollout status deployment/prometheus -n monitoring
            kubectl rollout status deployment/grafana -n monitoring
          '''
        }
      }
    }
  }

  post {
    failure {
      echo "Pipeline failed — rolling back"
      withCredentials([
        usernamePassword(
          credentialsId: 'aws-credentials',
          usernameVariable: 'AWS_ACCESS_KEY_ID',
          passwordVariable: 'AWS_SECRET_ACCESS_KEY'
        )
      ]) {
        sh '''
          export AWS_DEFAULT_REGION="${AWS_REGION}"
          kubectl rollout undo deployment/multi-agent-backend -n "${NAMESPACE}"
        '''
      }
    }
  }
}
